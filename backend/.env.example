PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# AI 中转站 / OpenAI兼容接口配置（推荐优先使用 AI_*）
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://ai.qaq.al/v1
AI_CHAT_PATH=/chat/completions
AI_API_KEY=your_api_key_here
AI_AUTH_SCHEME=Bearer
AI_CHAT_MODEL=gpt-5.2-codex
AI_CODER_MODEL=gpt-5.2-codex
AI_DEFAULT_MODEL=gpt-5.2-codex

# 若中转站要求额外请求头，可选
AI_EXTRA_HEADER_NAME=
AI_EXTRA_HEADER_VALUE=

# 兼容旧字段（仅兼容旧部署；若 QWEN_API_URL 填完整 /chat/completions 地址也可自动识别）
QWEN_API_KEY=
QWEN_API_URL=
QWEN_CODER_MODEL=
QWEN_MAX_MODEL=
QWEN_MODEL=

# 生产环境示例
# NODE_ENV=production
# FRONTEND_URL=https://sql-lj.netlify.app

FRONTEND_URL=http://localhost:5173
