PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# AI 中转站 / OpenAI兼容接口配置
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://your-relay.example.com/v1
AI_CHAT_PATH=/chat/completions
AI_API_KEY=your_api_key_here
AI_AUTH_SCHEME=Bearer
AI_CHAT_MODEL=qwen-max
AI_CODER_MODEL=qwen3-coder-plus
AI_DEFAULT_MODEL=qwen3-coder-plus

# 若中转站要求额外请求头，可选
AI_EXTRA_HEADER_NAME=
AI_EXTRA_HEADER_VALUE=

# 兼容旧字段（可不填）
QWEN_API_KEY=
QWEN_API_URL=
QWEN_CODER_MODEL=
QWEN_MAX_MODEL=
QWEN_MODEL=

FRONTEND_URL=http://localhost:5173
