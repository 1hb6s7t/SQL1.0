PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# AI 中转站 / OpenAI兼容接口配置（推荐优先使用 AI_*）
AI_PROVIDER=
AI_BASE_URL=
AI_CHAT_PATH=
AI_API_KEY=
AI_AUTH_SCHEME=
AI_CHAT_MODEL=
AI_CODER_MODEL=
AI_DEFAULT_MODEL=


# 若中转站要求额外请求头，可选
AI_EXTRA_HEADER_NAME=
AI_EXTRA_HEADER_VALUE=

# 生产环境示例
# NODE_ENV=production
# FRONTEND_URL=https://sql-lj.netlify.app

FRONTEND_URL=http://localhost:5173
